{
  "name": "@dispipe/presence",
  "version": "0.1.0",
  "description": "Discord Rich Presence client for JavaScript/TypeScript with IPC and WebSocket support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HarukaYamamoto0/dispipe.git",
    "directory": "packages/core"
  },
  "keywords": [
    "discord",
    "rpc",
    "rich-presence",
    "ipc",
    "websocket",
    "typescript"
  ],
  "author": "HarukaYamamoto0",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/HarukaYamamoto0/dispipe/issues"
  },
  "homepage": "https://github.com/HarukaYamamoto0/dispipe/tree/main/packages/core#readme",
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@dispipe/protocol": "workspace:*",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
